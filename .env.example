# Hugging Face token for voice cloning features.
# Leave blank if you only want built-in voices at first.
HF_TOKEN=

# Admin login for the local web UI
APP_USERNAME=admin
APP_PASSWORD=change_me

# Any long random string for session cookies
SESSION_SECRET=change_this_to_a_long_random_string

# Optional
PORT=8000
ENABLE_AUTH=true
